{
    "name": "lotse/musterung",
    "description": "Lotse Musterung — OIDC-Operator-Authentifizierung (Identität verifizieren + Rolle binden): fail-closed OIDC-Token-Verifikation nach ADR-0025 §2 (web-token/jwt-library) + JWKS-Bezug (HTTP/Cache). Implementiert die Lotse\\Rigg\\Auth-Verträge.",
    "type": "library",
    "license": "EUPL-1.2",
    "keywords": ["lotse", "musterung", "oidc", "oauth2", "auth", "jwt", "jwks"],
    "require": {
        "php": ">=8.4",
        "lotse/rigg": "^1.0",
        "psr/cache": "^3.0",
        "psr/clock": "^1.0",
        "symfony/http-client-contracts": "^3.0",
        "web-token/jwt-library": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/cache": "7.4.*",
        "symfony/clock": "7.4.*",
        "symfony/http-client": "7.4.*"
    },
    "suggest": {
        "symfony/cache": "PSR-6-Cache-Pool für den CachingHttpJwksProvider",
        "symfony/http-client": "Für den CachingHttpJwksProvider (JWKS-Bezug über HttpClientInterface)"
    },
    "autoload": {
        "psr-4": {
            "Lotse\\Musterung\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lotse\\Musterung\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
